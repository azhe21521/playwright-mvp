{
  "manifest_version": 3,
  "name": "Playwright MVP",
  "version": "1.0.0",
  "description": "Playwright MCP 中转扩展，打通远程开发机与本地调试机的通信限制",
  "permissions": [
    "debugger",
    "tabs",
    "activeTab",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/ui/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Playwright MVP"
  },
  "options_page": "src/ui/options/index.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
